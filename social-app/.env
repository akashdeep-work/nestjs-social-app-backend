REDIS_KEY_PREFIX=social-app
DEFAULT_CACHE_TTL=30000
USE_LOCAL_CONSOLE_FOR_AUDIT=true
GOOGLE_CLIENT_ID=add_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=add_fb_app_id
FACEBOOK_APP_SECRET=add_fb_secret
LINKEDIN_CLIENT_ID=add_linkedin_id
LINKEDIN_CLIENT_SECRET=add_linkedin_secret
JWT_SECRET=ASJHQ9382RT29WF0JIWOKEJ2987GTXSX
JWT_EXPIRY=1d
ANOMALY_DETECTOR_SERVICE_URL=http://anomaly-detector-dev:5000
NOTIFICATION_SERVICE_URL=http://notifications-dev:8000
HIBP_API_KEY=hibp_api_key
HIBP_USER_AGENT=NestJS-HIBP-Integration/1.0
HIBP_ENDPOINT=https://haveibeenpwned.com
IP_WHO_ENDPOINT=https://ipwho.is
# Twilio SMS/Calls
TWILIO_ACCOUNT_SID=_twilio_sid
TWILIO_VERIFY_SERVICE_SID=twilio_service_sid
TWILIO_AUTH_TOKEN=twilio_auth_token
