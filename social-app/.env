NODE_ENV=dev
SOCIAL_APP_SERVICE_URL=http://social-app-backend:8000
SOCIAL_APP_HTTP_PORT=8000
CORS_ORIGIN_REGEXP=http://social-app.com,https://social-app.com,http://localhost:3000,http://localhost:8000
NETWORK_NAME=my-local-network-dev
AZURE_STORAGE_CONNECTION_STRING=TBA
AZURE_STORAGE_CONTAINER_NAME=TBA
MONGODB_USER=dpuserdev
MONGODB_PASS=dppassdev
MONGODB_HOST=my-mongodb-social-app-dev
MONGODB_PORT=27017
MONGODB_NAME=social-app-backend
MONGO_DSN=mongodb://${MONGODB_USER}:${MONGODB_PASS}@${MONGODB_HOST}:${MONGODB_PORT}/${MONGODB_NAME}?authSource=admin
DB_REPLICA_SET=social-app
REDIS_HOST=redis-social-app
